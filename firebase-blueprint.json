{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "editor"] },
        "org_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "org_id"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "Organization invitations for new users",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "org_id": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor"] },
        "invited_by": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "expired"] },
        "created_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "org_id", "role", "status", "invited_by", "created_at", "expires_at"]
    },
    "ContentItem": {
      "title": "ContentItem",
      "description": "Unified content items for the InfoTV display",
      "type": "object",
      "properties": {
        "org_id": { "type": "string" },
        "type": { "type": "string", "enum": ["announcement", "event", "media", "qr", "mixed"] },
        "title": { "type": "string" },
        "body": { "type": ["string", "null"] },
        "media_url": { "type": ["string", "null"], "format": "uri" },
        "media_type": { "type": "string", "enum": ["none", "image", "video"] },
        "event_date": { "type": ["string", "null"], "format": "date" },
        "start_time": { "type": ["string", "null"] },
        "end_time": { "type": ["string", "null"] },
        "location": { "type": ["string", "null"] },
        "qr_url": { "type": ["string", "null"], "format": "uri" },
        "publish_start": { "type": ["string", "null"], "format": "date-time" },
        "publish_end": { "type": ["string", "null"], "format": "date-time" },
        "duration_seconds": { "type": "integer" },
        "is_published": { "type": "boolean" },
        "is_archived": { "type": "boolean" },
        "sort_order": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "updated_by": { "type": "string" }
      },
      "required": ["org_id", "type", "title", "is_published", "is_archived", "sort_order"]
    },
    "DisplaySettings": {
      "title": "DisplaySettings",
      "description": "Global settings for the InfoTV display",
      "type": "object",
      "properties": {
        "org_name": { "type": "string" },
        "welcome_text": { "type": ["string", "null"] },
        "rotation_interval_seconds": { "type": "integer" },
        "show_announcements": { "type": "boolean" },
        "show_events": { "type": "boolean" },
        "show_highlights": { "type": "boolean" },
        "show_qr_links": { "type": "boolean" },
        "show_opening_hours": { "type": "boolean" },
        "opening_hours_text": { "type": ["string", "null"] },
        "fallback_message": { "type": ["string", "null"] },
        "accent_color": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["org_name", "rotation_interval_seconds", "accent_color"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles"
    },
    "/invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "Organization invitations"
    },
    "/content_items/{itemId}": {
      "schema": "ContentItem",
      "description": "Unified content items"
    },
    "/display_settings/{settingsId}": {
      "schema": "DisplaySettings",
      "description": "Global display settings"
    }
  }
}
