rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        firestore.get(/databases/ai-studio-2dd96f32-2dae-4cf2-80ec-0bfb5309cfbd/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && 
        firestore.get(/databases/ai-studio-2dd96f32-2dae-4cf2-80ec-0bfb5309cfbd/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor'];
    }

    match /content/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /branding/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
