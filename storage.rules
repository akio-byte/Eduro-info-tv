rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /content/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == "aki.oksala@gmail.com" ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.org_id == orgId
      );
    }
  }
}
