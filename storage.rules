rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && getUserData().role in ['admin', 'editor'];
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && getUserData().org_id == orgId;
    }

    match /content/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if isEditor() && isOrgMember(orgId);
    }

    match /branding/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isOrgMember(orgId)
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
